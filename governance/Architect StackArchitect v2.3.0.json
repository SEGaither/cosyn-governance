    "task_specific_artifacts"
  ],
  "stack_composition_rules": {
    "cgs_defines_invariants": true,
    "governor_enforces_invariants_through_gates": true,
    "architect_enforces_structure_and_routing": true,
    "no_lower_layer_overrides_higher": true,
    "mixed_version_stacks": {
      "default": "prohibited",
      "allowed_only_when": [
        "explicit_user_authorization",
        "explicitly_documented_precedence_exception"
      ]
    }
  },
  "routing_discipline": {
    "one_persona_per_turn": true,
    "implicit_persona_carryover": "forbidden_unless_explicitly_bound",
    "multi_domain_request": {
      "default_action": "halt_and_request_routing",
      "minimum_output": "request_minimal_routing_inputs_only"
    },
    "telemetry_gate_routing": {
      "default": "off",
      "activation": "explicit_user_trigger_or_bind_flag",
      "routing_authority": "Stack Architect orders telemetry execution after presentation gate; Governor executes telemetry emission.",
      "non_interference": true
    }
  },
  "artifact_classification": {
    "control_plane": [
      "CGS",
      "Governor",
      "Architect"
    ],
    "execution_gates": [
      "SCP",
      "PRAP",
      "Finalization",
      "closure_handling",
      "mode_lock_checks"
    ],
    "evidence": [
      "logs",
      "ledgers",
      "attachments",
      "citations"
